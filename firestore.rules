rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated and verified as an administrator
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // 1. admin_users: Admin privilege documents
    match /admin_users/{userId} {
      // Allow users to read their own privilege document, and admins to read all
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Only existing admins can assign or modify administrator roles
      allow write: if isAdmin();
    }

    // 2. bookings: Client appointment schedules
    match /bookings/{bookingId} {
      // Anyone can submit a new booking request (from public forms)
      allow create: if true;
      // Only authenticated admins can read, update, or cancel bookings
      allow read, update, delete: if isAdmin();
    }

    // 3. services: Paint services catalog
    match /services/{serviceId} {
      // Anyone can view the services catalog
      allow read: if true;
      // Only admins can add, update, or delete services
      allow write: if isAdmin();
    }

    // 4. gallery: Projects portfolio
    match /gallery/{projectId} {
      // Anyone can view the completed projects portfolio
      allow read: if true;
      // Only admins can add, edit, or delete projects
      allow write: if isAdmin();
    }

    // 5. messages: Contact form inquiries
    match /messages/{messageId} {
      // Anyone can send an inquiry message
      allow create: if true;
      // Only admins can read or manage contact inquiries
      allow read, update, delete: if isAdmin();
    }

    // 6. admin_logs: Audit logs tracking admin updates
    match /admin_logs/{logId} {
      // Only authenticated admins can read or append logs
      allow read, write: if isAdmin();
    }

    // 7. inventory: Paint stock items
    match /inventory/{itemId} {
      // Only authenticated admins can read or write (CRUD) stock inventory
      allow read, write: if isAdmin();
    }

    // 8. color_cards: Paint color cards
    match /color_cards/{cardId} {
      // Anyone can read color cards for selection
      allow read: if true;
      // Only authenticated admins can modify color cards
      allow write: if isAdmin();
    }

    // 9. reviews: Public customer testimonials
    match /reviews/{reviewId} {
      // Anyone can read reviews and submit new feedback
      allow read, create: if true;
      // Only authenticated admins can edit or delete reviews
      allow update, delete: if isAdmin();
    }

    // Catch-all safety rule: Deny read/write access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
